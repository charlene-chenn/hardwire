ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here
# Optional: Other search keys if you decide to switch from DuckDuckGo

# Nemotron (Lambda Labs / any OpenAI-compatible endpoint)
# 1. On the GPU instance, clone and serve the model:
#    git clone https://huggingface.co/nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-BF16
#    python3 -m vllm.entrypoints.openai.api_server \
#      --model "nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-BF16" \
#      --dtype auto --trust-remote-code \
#      --served-model-name nemotron \
#      --host 0.0.0.0 --port 5000 \
#      --enable-auto-tool-choice --tool-call-parser qwen3_coder \
#      --reasoning-parser-plugin "NVIDIA-Nemotron-3-Nano-30B-A3B-BF16/nano_v3_reasoning_parser.py" \
#      --reasoning-parser nano_v3
# 2. Open SSH tunnel: ssh -L 5000:localhost:5000 ubuntu@<lambda-ip> -N
# 3. Set NEMOTRON_ENABLED=true and fill in the values below
NEMOTRON_ENABLED=false
NEMOTRON_ENDPOINT=http://localhost:5000/v1
NEMOTRON_API_KEY=null
NEMOTRON_MODEL=nemotron
